<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Navi" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/curve_dream</item>
        <item name="colorPrimaryVariant">@color/curve_dream</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>

    <style name="ToolbarTitleStyle">
        <item name="android:fontFamily">@font/alata</item>
        <item name="fontFamily">@font/alata</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="DrawerMenuTextStyle">
        <item name="android:fontFamily">@font/alata</item>
        <item name="fontFamily">@font/alata</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/curve_dream</item>
    </style>
</resources>